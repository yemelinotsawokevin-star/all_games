{% extends 'base.html.twig' %}

{% block title %}Game{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-16 px-6">

    <div class="max-w-4xl mx-auto bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-10">

        <h1 class="text-3xl font-bold text-white mb-8 tracking-tight">
            Game Details
        </h1>

        {% if game.image %}
            <div class="mb-8">
                <img src="{{ asset('images/games/' ~ game.image) }}"
                     class="max-w-xs rounded-2xl shadow-lg border border-white/10 hover:scale-105 transition duration-300">
            </div>
        {% endif %}

        <div class="overflow-hidden rounded-2xl border border-white/10">
            <table class="w-full text-left">
                <tbody class="divide-y divide-white/10 text-slate-300">

                    <tr class="hover:bg-white/5 transition">
                        <th class="px-6 py-4 font-semibold text-slate-400 w-1/3">Id</th>
                        <td class="px-6 py-4 text-white font-medium">{{ game.id }}</td>
                    </tr>

                    <tr class="hover:bg-white/5 transition">
                        <th class="px-6 py-4 font-semibold text-slate-400">Title</th>
                        <td class="px-6 py-4 text-white">{{ game.title }}</td>
                    </tr>

                    <tr class="hover:bg-white/5 transition">
                        <th class="px-6 py-4 font-semibold text-slate-400">Description</th>
                        <td class="px-6 py-4 text-slate-300 leading-relaxed">{{ game.description }}</td>
                    </tr>

                    <tr class="hover:bg-white/5 transition">
                        <th class="px-6 py-4 font-semibold text-slate-400">Image</th>
                        <td class="px-6 py-4 text-slate-300">{{ game.image }}</td>
                    </tr>

                    <tr class="hover:bg-white/5 transition">
                        <th class="px-6 py-4 font-semibold text-slate-400">Price</th>
                        <td class="px-6 py-4 font-bold bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
                            {{ game.price }} €
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">

            <a href="{{ path('app_admin_game_index') }}"
               class="inline-flex items-center justify-center px-6 py-3 rounded-xl
                      bg-white/10 hover:bg-white/20
                      border border-white/10
                      text-white font-semibold transition">
                ← Back to list
            </a>

            <a href="{{ path('app_admin_game_edit', {'id': game.id}) }}"
               class="inline-flex items-center justify-center px-6 py-3 rounded-xl
                      bg-indigo-600 hover:bg-indigo-500
                      text-white font-semibold shadow-md transition">
                ✏️ Edit
            </a>

            <div>
                {{ include('admin_game/_delete_form.html.twig') }}
            </div>

        </div>

    </div>

</div>
{% endblock %}