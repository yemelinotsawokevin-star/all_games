{% extends 'base.html.twig' %}

{% block title %}Create New Game | AllGames{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#0f172a] py-12 px-6">

    <div class="max-w-3xl mx-auto">

        {# Card container #}
        <div class="bg-[#111b2c] border border-white/10 rounded-2xl shadow-2xl p-8">

            <h1 class="text-2xl font-bold text-white mb-8 flex items-center gap-2">
                🎮 Create New Game
            </h1>

            {{ form_start(form) }}

            {# TITLE #}
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Game Title
                </label>
                {{ form_widget(form.title, {
                    attr: {
                        class: 'w-full bg-[#0f172a] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition'
                    }
                }) }}
            </div>

            {# DESCRIPTION #}
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Game Description
                </label>
                {{ form_widget(form.description, {
                    attr: {
                        class: 'w-full bg-[#0f172a] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition',
                        rows: 5
                    }
                }) }}
            </div>

            {# PRICE #}
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Price (€)
                </label>
                {{ form_widget(form.price, {
                    attr: {
                        class: 'w-full bg-[#0f172a] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition'
                    }
                }) }}
            </div>

            {# CATEGORY #}
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Category
                </label>
                {{ form_widget(form.category, {
                    attr: {
                        class: 'w-full bg-[#0f172a] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition'
                    }
                }) }}
            </div>

            {# ✅ RELEASE YEAR DESIGN #}
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Release Year
                </label>

                <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 hover:bg-white/10 transition duration-300">
                    <div class="flex items-center gap-3">

                        <div class="bg-blue-600/20 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 class="w-5 h-5 text-blue-400"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M6 2v2M18 2v2M3 8h18M5 6h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z"/>
                            </svg>
                        </div>

                        {{ form_widget(form.releaseYear, {
                            attr: {
                                class: 'w-full bg-transparent text-white focus:outline-none text-sm'
                            }
                        }) }}

                    </div>
                </div>
            </div>

            {# IMAGE UPLOAD #}
            <div class="mb-8">
                <label class="block text-sm font-semibold text-gray-300 mb-2">
                    Game Image (JPG / PNG / WebP)
                </label>

                <div class="relative border-2 border-dashed border-white/20 rounded-xl p-6 text-center bg-[#0f172a] hover:border-blue-500 transition cursor-pointer">

                    {{ form_widget(form.imageFile, {
                        attr: {
                            class: 'absolute inset-0 w-full h-full opacity-0 cursor-pointer'
                        }
                    }) }}

                    <div class="text-gray-400 text-sm">
                        📁 Click to upload image
                    </div>
                </div>
            </div>

            {# SAVE BUTTON #}
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-semibold transition shadow-lg hover:shadow-blue-500/20">
                💾 Save Game
            </button>

            {{ form_end(form) }}

        </div>

    </div>
</div>
{% endblock %}