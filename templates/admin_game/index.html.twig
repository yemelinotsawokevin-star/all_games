{% extends 'base.html.twig' %}

{% block title %}Admin - Games{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-10">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-white">Admin - Games</h1>

        <a href="{{ path('app_admin_game_new') }}"
           class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-semibold transition">
            + Create new
        </a>
    </div>

    {# Flash #}
    {% for message in app.flashes('success') %}
        <div class="mb-6 p-3 rounded bg-green-700/30 border border-green-500 text-green-200">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-6 p-3 rounded bg-red-700/30 border border-red-500 text-red-200">
            {{ message }}
        </div>
    {% endfor %}

    <div class="overflow-x-auto bg-[#0b1220] border border-white/10 rounded-2xl shadow-lg">
        <table class="min-w-full table-fixed text-sm">
            <thead class="bg-white/5 text-gray-300">
            <tr>
                <th class="w-16 px-4 py-3 text-left font-semibold">Id</th>
                <th class="w-48 px-4 py-3 text-left font-semibold">Title</th>
                <th class="w-40 px-4 py-3 text-left font-semibold">Category</th>
                <th class="w-32 px-4 py-3 text-left font-semibold">Release</th>
                <th class="w-[28rem] px-4 py-3 text-left font-semibold">Description</th>
                <th class="w-72 px-4 py-3 text-left font-semibold">Image</th>
                <th class="w-28 px-4 py-3 text-right font-semibold">Price</th>
                <th class="w-40 px-4 py-3 text-right font-semibold">Actions</th>
            </tr>
            </thead>

            <tbody class="divide-y divide-white/10">
            {% for game in games %}
                <tr class="hover:bg-white/5 align-top">
                    <td class="px-4 py-4 text-gray-300">{{ game.id }}</td>

                    <td class="px-4 py-4 font-semibold text-white">
                        <div class="truncate">{{ game.title }}</div>
                    </td>

                    <td class="px-4 py-4">
                        {% if game.category %}
                            <span class="inline-flex items-center rounded-full bg-blue-600/20 border border-blue-500/30 px-3 py-1 text-xs text-blue-300">
                                {{ game.category }}
                            </span>
                        {% else %}
                            <span class="text-gray-500">—</span>
                        {% endif %}
                    </td>

                    <td class="px-4 py-4 text-gray-300">
                        {{ game.releaseYear ?? '—' }}
                    </td>

                    <td class="px-4 py-4 text-gray-300">
                        <div class="line-clamp-3">
                            {{ game.description }}
                        </div>
                    </td>

                    <td class="px-4 py-4">
                        <div class="flex items-center gap-3">
                            <div class="h-12 w-12 overflow-hidden rounded-lg border border-white/10 bg-black/20 flex items-center justify-center">
                                {% if game.image %}
                                    <img
                                        src="{{ asset('images/games/' ~ game.image) }}"
                                        alt="{{ game.title }}"
                                        class="h-full w-full object-cover"
                                        onerror="this.style.display='none';"
                                    >
                                {% else %}
                                    <span class="text-gray-500 text-xs">—</span>
                                {% endif %}
                            </div>

                            <div class="text-xs text-gray-400 truncate max-w-[14rem]">
                                {{ game.image ?? 'No image' }}
                            </div>
                        </div>
                    </td>

                    <td class="px-4 py-4 text-right font-bold text-blue-300">
                        {{ game.price }} €
                    </td>

                    <td class="px-4 py-4">
                        <div class="flex justify-end gap-2">
                            <a href="{{ path('app_admin_game_show', {id: game.id}) }}"
                               class="bg-white/10 hover:bg-white/15 border border-white/10 text-white px-3 py-2 rounded-md text-xs font-semibold transition">
                                Show
                            </a>
                            <a href="{{ path('app_admin_game_edit', {id: game.id}) }}"
                               class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded-md text-xs font-semibold transition">
                                Edit
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="px-4 py-6 text-center text-gray-400">
                        no records found
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}