{% extends 'base.html.twig' %}

{% block title %}AllGames - Games{% endblock %}

{% block body %}
<div class="bg-[#0f172a]">
    <div class="container mx-auto px-6 py-10">

        <div class="flex items-center justify-between gap-6 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-white">Games</h1>
                <p class="text-gray-400 text-sm mt-1">
                    {% if q is defined and q %}
                        Résultats pour “{{ q }}” ({{ games|length }})
                    {% else %}
                        Tous les jeux ({{ games|length }})
                    {% endif %}
                </p>
            </div>

            {% if q is defined and q %}
                <a href="{{ path('app_game_index') }}"
                   class="bg-white/10 hover:bg-white/15 border border-white/10 text-white px-4 py-2 rounded-md text-sm font-semibold transition">
                    Réinitialiser
                </a>
            {% endif %}
        </div>

        {% if games|length == 0 %}
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-gray-300">
                Aucun jeu trouvé.
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for game in games %}
                    <a href="{{ path('app_game_show', { id: game.id }) }}"
                       class="bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden hover:border-blue-500 transition shadow-lg block">

                        <div class="h-52 bg-black/20 flex items-center justify-center overflow-hidden">
                            {% if game.image %}
                                <img src="{{ asset('images/games/' ~ game.image) }}"
                                     alt="{{ game.title }}"
                                     class="w-full h-full object-cover"
                                     onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=&quot;text-gray-400&quot;>Image indisponible</div>';">
                            {% else %}
                                <div class="text-gray-400">Aucune image</div>
                            {% endif %}
                        </div>

                        <div class="p-6">
                            <div class="flex items-start justify-between gap-3">
                                <h3 class="text-lg font-semibold text-white">
                                    {{ game.title }}
                                </h3>
                                <span class="text-blue-300 font-extrabold whitespace-nowrap">
                                    {{ game.price }} €
                                </span>
                            </div>

                            {% if game.category %}
                                <div class="mt-3">
                                    <span class="inline-flex items-center rounded-full bg-white/10 border border-white/10 px-3 py-1 text-xs text-gray-200">
                                        {{ game.category }}
                                    </span>
                                </div>
                            {% endif %}

                            <p class="mt-3 text-gray-400 text-sm line-clamp-3">
                                {{ game.description }}
                            </p>

                            <div class="mt-4 text-blue-400 text-sm font-semibold">
                                Voir le détail →
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}