{% extends 'base.html.twig' %}

{% block title %}AllGames - Home{% endblock %}

{% block body %}

<section class="bg-[#0f172a] py-20">
    <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <h1 class="text-4xl font-bold text-white mb-6">Wishlist all your favorite games</h1>
            <p class="text-gray-400 mb-8 leading-relaxed">
                Keep track of the games you love, stay informed about new releases,
                and never miss a deal. Build a wishlist of must-play titles in one place.
            </p>

            <a href="{{ path('app_game_index') }}"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md font-semibold transition shadow-md inline-block">
                View all games
            </a>
        </div>

        <div class="flex justify-center lg:justify-end">
            <img src="{{ asset('images/logo-all-games.svg') }}" alt="AllGames" class="w-[380px] opacity-90">
        </div>
    </div>
</section>

<section class="bg-[#0f172a] pb-20">
    <div class="container mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-white">Featured Games</h2>
            <a href="{{ path('app_game_index') }}" class="text-blue-400 hover:text-blue-300 text-sm font-semibold transition">
                Browse all →
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for game in games|slice(0, 3) %}
                <a href="{{ path('app_game_show', { id: game.id }) }}"
                   class="bg-[#1e293b] rounded-xl overflow-hidden shadow-lg border border-white/10 hover:border-blue-500 transition block">

                    <div class="h-52 overflow-hidden bg-black/20 flex items-center justify-center">
                        {% if game.image %}
                            <img src="{{ asset('images/games/' ~ game.image) }}" alt="{{ game.title }}"
                                 class="w-full h-52 object-cover">
                        {% else %}
                            <div class="text-gray-400">Aucune image</div>
                        {% endif %}
                    </div>

                    <div class="p-6">
                        <h3 class="text-lg font-semibold text-white mb-2">{{ game.title }}</h3>
                        <p class="text-gray-400 text-sm mb-4 line-clamp-3">{{ game.description }}</p>

                        <div class="flex items-center justify-between">
                            <span class="text-blue-400 font-bold">{{ game.price }} €</span>
                            <span class="text-blue-400 text-sm hover:underline">Learn more →</span>
                        </div>
                    </div>
                </a>
            {% else %}
                <p class="text-gray-400">No games available.</p>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}