{% extends 'base.html.twig' %}

{% block title %}About | AllGames{% endblock %}

{% block body %}
<section class="bg-[#0f172a]">
    <div class="container mx-auto px-6 py-16">

        <div class="bg-[#111b2c] border border-white/10 rounded-2xl shadow-lg overflow-hidden">

            {# zone centrale comme l'image #}
            <div class="px-6 py-20 text-center">

                <div class="flex justify-center mb-10">
                    <img src="{{ asset('images/logo-all-games.svg') }}"
                         alt="AllGames"
                         class="w-[360px] max-w-full opacity-95">
                </div>

                <h1 class="text-2xl font-bold text-white mb-4">
                    About AllGames
                </h1>

                <p class="text-gray-400 text-sm leading-relaxed max-w-3xl mx-auto">
                    We're dedicated to connecting gamers with the titles they love.
                    Our mission is to simplify how you discover, wishlist, and track the best games across all genres and platforms.
                    Whether you're an avid collector or seeking your next favorite pastime, we're here to help you explore new adventures
                    and get the most out of your gaming journey.
                </p>

            </div>

        </div>

    </div>
</section>
{% endblock %}